# PostgreSQL connection (required). Use this for local dev; override in production.
# For Supabase Postgres: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://agile:agile@localhost:5432/agile

# Supabase Auth (required for JWT verification when auth is enabled).
# Get these from: Supabase Dashboard → Settings → API
# JWT Secret: Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# OpenAI (for AI summary and simulation recommendations). Optional for basic CRUD.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=10.0

# CORS allowed origins, comma-separated. Set in production (e.g. Vercel frontend URL).
# CORS_ORIGINS=https://your-app.vercel.app

# Risk detection thresholds (optional)
# RISK_OVERDUE_THRESHOLD_DAYS=3
# RISK_STALLED_THRESHOLD_DAYS=7
# RISK_REQUIRED_OVERDUE_COUNT=2
