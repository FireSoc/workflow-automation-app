# PostgreSQL connection (required). Use this for local dev; override in production.
DATABASE_URL=postgresql://agile:agile@localhost:5432/agile

# OpenAI (for AI summary and simulation recommendations). Optional for basic CRUD.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=10.0

# Risk detection thresholds (optional)
# RISK_OVERDUE_THRESHOLD_DAYS=3
# RISK_STALLED_THRESHOLD_DAYS=7
# RISK_REQUIRED_OVERDUE_COUNT=2
